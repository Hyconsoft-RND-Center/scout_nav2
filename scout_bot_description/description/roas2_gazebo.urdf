      <geometry>
        <!-- <mesh filename="package://scout_bot_description/meshes/include/Frame.stl"/> -->
        <mesh filename="file:///home/hycon/gazebo_nav/install/scout_bot_description/share/scout_bot_description/meshes/include/Frame.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
